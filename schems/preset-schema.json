{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "preset-schema.json",
  "title": "Load Balancer Benchmark Preset",
  "description": "Схема для описания одного эксперимента по нагрузочному тестированию балансировщика",
  "type": "object",
  "required": ["name", "servers", "client_groups"],
  "properties": {
    "name": { "type": "string", "description": "Уникальное имя эксперимента" },
    "description": { "type": "string", "default": "", "description": "Произвольное описание" },
    "seed": { "type": "integer", "description": "Зерно для генератора случайных чисел" },
    "duration_ms": { "type": "integer", "minimum": 0, "default": 30000, "description": "Длительность теста (мс)" },
    "warmup_ms": { "type": "integer", "minimum": 0, "default": 0, "description": "Время прогрева (мс)" },
    "total_request_limit": { "type": "integer", "minimum": 0, "default": 0, "description": "Глобальное ограничение по числу запросов" },
    "manager_workers": { "type": "integer", "minimum": 0, "default": 0, "description": "Число воркеров менеджера (0 = синхронный)" },
    "servers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "common-defs.json#/$defs/server_config" }
    },
    "server_model_params": { "$ref": "common-defs.json#/$defs/server_model_params" },
    "client_groups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "common-defs.json#/$defs/client_group_config" }
    }
  }
}