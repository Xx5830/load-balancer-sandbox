{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common-defs.json",
  "title": "Common definitions for load balancer presets and results",
  "$defs": {
    "generator": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["constant", "uniform", "normal", "exponential", "lognormal", "sequence"]
        },
        "value": { "type": "number", "description": "Значение для constant" },
        "min": { "type": "number", "description": "Минимум для uniform / опциональная нижняя граница для normal, lognormal" },
        "max": { "type": "number", "description": "Максимум для uniform / опциональная верхняя граница для normal, lognormal" },
        "center": { "type": "number", "description": "Центр распределения (mean) для normal, lognormal; среднее для exponential" },
        "deviation": { "type": "number", "description": "Стандартное отклонение для normal, lognormal" },
        "values": { "type": "array", "items": { "type": "number" }, "description": "Массив значений для sequence" }
      },
      "allOf": [
        { "if": { "properties": { "type": { "const": "constant" } } }, "then": { "required": ["value"] } },
        { "if": { "properties": { "type": { "const": "uniform" } } }, "then": { "required": ["min", "max"] } },
        { "if": { "properties": { "type": { "const": "normal" } } }, "then": { "required": ["center", "deviation"] } },
        { "if": { "properties": { "type": { "const": "exponential" } } }, "then": { "required": ["center"] } },
        { "if": { "properties": { "type": { "const": "lognormal" } } }, "then": { "required": ["center", "deviation"] } },
        { "if": { "properties": { "type": { "const": "sequence" } } }, "then": { "required": ["values"] } }
      ]
    },
    "generator_or_array": {
      "oneOf": [
        { "type": "array", "items": { "type": "number" } },
        { "$ref": "common-defs.json#/$defs/generator" }
      ]
    },
    "generator_or_number": {
      "oneOf": [
        { "type": "number", "minimum": 0, "maximum": 1 },
        { "$ref": "common-defs.json#/$defs/generator" }
      ]
    },
    "server_model_params": {
      "type": "object",
      "properties": {
        "load_recovery_rate": { "type": "number", "default": 0.25, "description": "Скорость восстановления нагрузки" },
        "load_slowdown_factor": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.9, "description": "Фактор замедления от загрузки" },
        "task_load_factor": { "type": "number", "default": 0.35, "description": "Вклад задачи в загрузку" },
        "connection_load_factor": { "type": "number", "default": 0.04, "description": "Вклад соединения в загрузку" },
        "min_task_seconds": { "type": "number", "default": 0.001, "description": "Минимальное время задачи (сек)" },
        "reject_threshold_seconds": { "type": "number", "default": 5.0, "description": "Базовый порог отклонения задачи (сек)" },
        "overload_reject_factor": { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0, "description": "Чувствительность порога к загрузке (0 – статичный, 1 – макс. чувствительность)" },
        "min_weight_factor": { "type": "number", "default": 0.08, "description": "Минимальная доля мощности при полной загрузке" }
      }
    },
    "server_config": {
      "type": "object",
      "required": ["weight"],
      "properties": {
        "weight": { "type": "integer", "exclusiveMinimum": 0, "description": "Вес сервера" },
        "capacity": { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0, "description": "Коэффициент производительности (0..1)" },
        "background_load": {
          "$ref": "common-defs.json#/$defs/generator_or_number",
          "default": 0.0,
          "description": "Фоновая загрузка (число или генератор)"
        },
        "max_parallel_requests": { "type": "integer", "minimum": 1, "default": 1, "description": "Размер пула потоков сервера" },
        "start_at_ms": { "type": "integer", "minimum": 0, "default": 0, "description": "Время появления сервера (мс)" },
        "crash_at_ms": { "type": ["integer", "null"], "default": null, "description": "Время падения (мс), null – не падает" },
        "model_params": { "$ref": "common-defs.json#/$defs/server_model_params", "description": "Индивидуальные параметры модели" }
      }
    },
    "client_group_config": {
      "type": "object",
      "required": ["count", "inter_arrival_ms", "task_cost"],
      "properties": {
        "count": { "type": "integer", "exclusiveMinimum": 0, "description": "Число клиентов в группе" },
        "sticky_scope": { "type": "string", "enum": ["none", "client", "group"], "default": "none", "description": "Режим аффинности" },
        "inter_arrival_ms": { "$ref": "common-defs.json#/$defs/generator_or_array", "description": "Интервал между запросами (мс)" },
        "task_cost": { "$ref": "common-defs.json#/$defs/generator", "description": "Стоимость задачи" },
        "max_requests": { "type": "integer", "minimum": 0, "default": 0, "description": "Лимит запросов на клиента" },
        "active_windows": {
          "type": "array",
          "description": "Окна активности",
          "items": {
            "type": "object",
            "required": ["start_ms", "end_ms"],
            "properties": {
              "start_ms": { "type": "integer", "minimum": 0 },
              "end_ms": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "retry_policy": {
          "type": "object",
          "properties": {
            "max_retries": { "type": "integer", "minimum": 0, "default": 0, "description": "Максимум повторов" },
            "delay_ms": { "$ref": "common-defs.json#/$defs/generator", "default": { "type": "constant", "value": 0 }, "description": "Задержка перед повтором (мс)" },
            "timeout_ms": { "type": "integer", "minimum": 0, "default": 0, "description": "Общий таймаут на все попытки (мс)" }
          }
        }
      }
    }
  }
}